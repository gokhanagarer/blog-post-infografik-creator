# Demo runs WITHOUT any of these set — the Pillow placeholder generator produces
# real branded images so reviewers can verify the full pipeline in 30 seconds.

# Pick a backend:
#   placeholder   (default) offline Pillow-rendered placeholder
#   pollinations  free Flux image gen via Pollinations.ai, no API key
#   gemini        Google Gemini 2.5 image model, requires GEMINI_API_KEY
IMAGE_BACKEND=placeholder

# Required when IMAGE_BACKEND=gemini
GEMINI_API_KEY=
